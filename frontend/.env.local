# Local development environment variables
# This file is gitignored and will NOT be committed to the repo.
# Copy this to your local machine and fill in real values.

# Backend API URL — REQUIRED
# Make sure your backend is running on this port before starting the frontend.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8001

# Supabase — fill in your project values
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
