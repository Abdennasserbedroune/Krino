# ─────────────────────────────────────────────────────────────────────────────
# Krino — Local Development Environment Variables
# Copy this file to .env.local and fill in your real keys.
#   cp .env.example .env.local
# Never commit .env.local — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────


# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL — found in Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon (public) key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key — SERVER SIDE ONLY, never expose to the browser
# Used for admin operations (e.g. bypassing RLS in API routes)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# ── Groq ──────────────────────────────────────────────────────────────────────
# Used for:
#   • LLM inference  → llama-3.3-70b-versatile  (interview questions + evaluation)
#   • Whisper STT    → whisper-large-v3          (/api/v1/interview-prep/live/transcribe)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key


# ── HuggingFace ───────────────────────────────────────────────────────────────
# Used for TTS:
#   Primary  → hexgrad/Kokoro-82M      (natural voice, may cold-start)
#   Fallback → microsoft/speecht5_tts  (robotic but always warm)
# Free read-only token is enough.
# Get your token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your_huggingface_token


# ── OpenRouter (optional — future LLM fallback) ───────────────────────────────
# Not used in the current codebase but recommended to set now.
# Gives access to GPT-4o, Claude, Gemini etc. as fallback models.
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your_openrouter_key


# ── App URL ───────────────────────────────────────────────────────────────────
# Used for absolute URL construction in server-side code and emails.
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─────────────────────────────────────────────────────────────────────────────
# Quick start:
#   cd frontend
#   cp .env.example .env.local
#   # fill in the values above
#   npm install
#   npm run dev
# ─────────────────────────────────────────────────────────────────────────────
