# =============================================================================
# Backend Environment Variables - PLACEHOLDER VALUES ONLY
# =============================================================================
# 
# SECURITY WARNING: DO NOT commit real API keys, secrets, or credentials.
# 
# For local development: Copy to .env and fill in real values
# For production deployment: Set these in your hosting platform's environment config
# =============================================================================

# Server Configuration
NODE_ENV=development
PORT=8000

# Database Configuration
# Local: postgresql://pathwise:pathwise@localhost:5432/pathwise
# Production (example Supabase Postgres):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.cvhfeqfmfmbdxouzzxkx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@your-db-host.supabase.co:5432/postgres

# File Storage
FILE_STORAGE_ROOT=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Groq AI Configuration
# CRITICAL: Never commit your real API key
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_real_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.7

# CORS Configuration
# Local: http://localhost:3000
# Production: Your deployed frontend URL (e.g., https://your-app.vercel.app)
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Endpoint-specific Rate Limits (aligned with Groq free-tier constraints)
UPLOAD_RATE_LIMIT_POINTS=10
UPLOAD_RATE_LIMIT_DURATION=3600

ANALYSIS_RATE_LIMIT_POINTS=20
ANALYSIS_RATE_LIMIT_DURATION=3600

CHAT_RATE_LIMIT_POINTS=30
CHAT_RATE_LIMIT_DURATION=60

CV_RATE_LIMIT_POINTS=50
CV_RATE_LIMIT_DURATION=3600

# JWT Authentication
# CRITICAL: Generate a secure random secret for production
# Generate with: openssl rand -hex 32
JWT_SECRET=your-secure-jwt-secret-here-minimum-32-characters
JWT_EXPIRES_IN=7d
